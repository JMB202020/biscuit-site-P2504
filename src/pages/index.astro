    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Left: contact info -->
        <div>
          <span class="inline-block bg-white/20 text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6">Get in Touch</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">Ready to Book?</h2>
          <p class="text-white/80 text-lg leading-relaxed mb-8">Get in touch today for a free meet-and-greet. We would love to meet you and your pets before we get started.</p>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-[var(--color-brand-accent)] rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white">📞</span>
              </div>
              <div>
                <p class="text-white/60 text-xs uppercase tracking-wide font-semibold">Phone</p>
                <a href="tel:+447961765506" class="text-white font-bold text-lg hover:text-[var(--color-brand-accent)] transition-colors">07961 765506</a>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-[var(--color-brand-accent)] rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white">📍</span>
              </div>
              <div>
                <p class="text-white/60 text-xs uppercase tracking-wide font-semibold">Location</p>
                <p class="text-white font-bold text-lg">Sutton Coldfield</p>
              </div>
            </div>
          </div>
        </div>
        <!-- Right: contact form -->
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <h3 class="text-xl font-extrabold text-[var(--color-ink)] mb-6">Send Us a Message</h3>
          <form action="https://formspree.io/f/mwvaaojq" method="POST" class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-semibold text-[var(--color-ink)] mb-1">Your Name</label>
              <input type="text" id="name" name="name" required placeholder="Jane Smith" class="w-full border border-[var(--color-border)] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-primary)]" />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-[var(--color-ink)] mb-1">Email Address</label>
              <input type="email" id="email" name="email" required placeholder="jane@example.com" class="w-full border border-[var(--color-border)] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-primary)]" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-[var(--color-ink)] mb-1">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="07700 000000" class="w-full border border-[var(--color-border)] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-primary)]" />
            </div>
            <div>
              <label for="service" class="block text-sm font-semibold text-[var(--color-ink)] mb-1">Service Required</label>
              <select id="service" name="service" class="w-full border border-[var(--color-border)] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-primary)] bg-white">
                <option value="">Please select...</option>
                <option value="dog-walking">Dog Walking</option>
                <option value="home-sitting">Home Pet Sitting</option>
                <option value="overnight">Overnight Stay</option>
                <option value="drop-in">Drop-in Visit</option>
                <option value="unsure">Not sure yet</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-[var(--color-ink)] mb-1">Tell Us About Your Pet</label>
              <textarea id="message" name="message" rows="3" placeholder="Breed, age, any special needs..." class="w-full border border-[var(--color-border)] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-primary)] resize-none"></textarea>
            </div>
            <input type="hidden" name="_subject" value="New enquiry from PAWfect Friends website" />
            <button type="submit" class="w-full bg-[var(--color-brand-primary)] hover:bg-[var(--color-brand-primary-deep)] text-white font-bold py-3 px-6 rounded-lg transition-colors">
              Send Enquiry 🐾
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
