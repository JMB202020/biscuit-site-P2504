            <li><a href="#services" class="hover:text-white transition-colors">Services</a></li>
            <li><a href="#coverage" class="hover:text-white transition-colors">Coverage Area</a></li>
            <li><a href="#about" class="hover:text-white transition-colors">About Us</a></li>
            <li><a href="#pricing" class="hover:text-white transition-colors">Pricing</a></li>
            <li><a href="#contact" class="hover:text-white transition-colors">Get in Touch</a></li>
          </ul>
        </div>
        <!-- Contact -->
        <div>
          <h4 class="font-extrabold text-[var(--color-brand-accent)] uppercase tracking-wide text-xs mb-4">Contact</h4>
          <ul class="space-y-2 text-sm text-white/70">
            <li class="flex items-center gap-2"><span>📞</span> <a href="tel:+447961765506" class="hover:text-white transition-colors">07961 765506</a></li>
            <li class="flex items-center gap-2"><span>📍</span> Sutton Coldfield</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-white/40 text-xs">
        <span>&copy; {new Date().getFullYear()} PAWfect Friends. All rights reserved.</span>
        <span>This is a sample site built by <a href="https://biscuitweb.co.uk" class="underline hover:text-white/70">Biscuit Web</a> to showcase our work.</span>
